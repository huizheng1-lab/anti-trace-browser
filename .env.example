# Anti-Trace Browser — local environment overrides
# Copy to `.env` (same folder as main.py) and fill in. The `.env` file is
# gitignored, so it never gets committed. Real shell env vars take precedence.

# --- MiniMax AI agent (optional) ---
# Without a key, the rule-based agent still works for simple commands.
# Get one at https://www.minimax.io/platform (global) or minimaxi.com (China).
MINIMAX_API_KEY=

# Region: "global" (api.minimax.io) or "china" (api.minimaxi.com)
MINIMAX_REGION=global

# Model name accepted by your account. Common values:
#   MiniMax-M2
#   abab6.5s-chat
#   abab6.5t-chat
MINIMAX_MODEL=MiniMax-M2
